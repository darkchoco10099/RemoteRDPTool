<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RemoteRDPTool.Views.CredentialPromptWindow"
        Width="520"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="输入凭据">
  <Grid Margin="20" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
    <TextBlock Text="连接" VerticalAlignment="Center" />
    <TextBlock x:Name="TargetBlock" Grid.Column="1" VerticalAlignment="Center" />

    <TextBlock Grid.Row="1" Text="账号" VerticalAlignment="Center" />
    <TextBox x:Name="UserBox" Grid.Row="1" Grid.Column="1" />

    <TextBlock Grid.Row="2" Text="密码" VerticalAlignment="Center" />
    <TextBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="1" PasswordChar="●" />

    <CheckBox x:Name="SaveCheckBox" Grid.Row="3" Grid.ColumnSpan="2" Content="保存到配置文件" />

    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
      <Button Content="取消" Click="Cancel_Click" />
      <Button Content="连接" IsDefault="True" Click="Connect_Click" />
    </StackPanel>
  </Grid>
</Window>
