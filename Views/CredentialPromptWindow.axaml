<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RemoteRDPTool.Views.CredentialPromptWindow"
        Width="520"
        SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/logo.ico"
        Background="Transparent"
        Title="输入凭据">
  <Window.Styles>
    <Style Selector="Button.primaryAction">
      <Setter Property="Background" Value="#0B75D1" />
      <Setter Property="BorderBrush" Value="#0B75D1" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style Selector="Button.secondaryAction">
      <Setter Property="Background" Value="#29282D" />
      <Setter Property="BorderBrush" Value="#4A4950" />
      <Setter Property="Foreground" Value="#EAF0FC" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="36" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D7DEE8" />
    </Style>
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="Foreground" Value="#2A2F36" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.dialogTitle">
      <Setter Property="Foreground" Value="#1B1F24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.titleClose">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#6B7280" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.titleClose:pointerover">
      <Setter Property="Background" Value="#EEF2F8" />
    </Style>
  </Window.Styles>

  <Border Margin="0"
          Background="#FFFFFF"
          BorderBrush="#D7DEE8"
          BorderThickness="1"
          CornerRadius="14"
          BoxShadow="0 0 0 0 Transparent"
          Padding="18">
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
      <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" PointerPressed="TitleBar_PointerPressed">
        <TextBlock Classes="dialogTitle" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Classes="titleClose" Content="×" Click="Cancel_Click" />
      </Grid>

      <TextBlock Classes="fieldLabel" Grid.Row="1" Text="连接" VerticalAlignment="Center" />
      <TextBlock x:Name="TargetBlock" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" />

      <TextBlock Classes="fieldLabel" Grid.Row="2" Text="账号" VerticalAlignment="Center" />
      <TextBox x:Name="UserBox" Grid.Row="2" Grid.Column="1" />

      <TextBlock Classes="fieldLabel" Grid.Row="3" Text="密码" VerticalAlignment="Center" />
      <TextBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" PasswordChar="●" />

      <CheckBox x:Name="SaveCheckBox" Grid.Row="4" Grid.ColumnSpan="2" Content="保存到配置文件" />

      <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
        <Button Classes="secondaryAction" Content="取消" Click="Cancel_Click" />
        <Button Classes="primaryAction" Content="连接" IsDefault="True" Click="Connect_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
