<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteRDPTool.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RemoteRDPTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="RemoteRDPTool"
        MinWidth="980"
        MinHeight="640">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeight" Value="40" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SystemControlAcrylicWindowBrush}">
        <Border Padding="16,14" Background="{DynamicResource SystemControlAcrylicElementBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center" ColumnSpacing="14">
                <StackPanel Orientation="Vertical" Spacing="2">
                    <TextBlock Text="RemoteRDPTool" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="RDP 连接管理" Opacity="0.75" FontSize="12" />
                </StackPanel>
                <TextBox Grid.Column="1"
                         Watermark="搜索 名称 / 主机 / 账号 / 分组"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Content="新增连接" Command="{Binding AddConnectionCommand}" />
                    <Button Content="新增分组" Command="{Binding AddGroupCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16">
            <ItemsControl ItemsSource="{Binding GroupViews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SystemControlAcrylicElementBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                            <Expander IsExpanded="{Binding IsExpanded}">
                                <Expander.Header>
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Count}" Opacity="0.65" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="新增连接"
                                                Command="{Binding DataContext.AddConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Name}" />
                                        <Button Grid.Column="2"
                                                Content="重命名"
                                                IsVisible="{Binding CanManage}"
                                                Command="{Binding DataContext.RenameGroupByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Name}" />
                                        <Button Grid.Column="3"
                                                Content="删除"
                                                IsVisible="{Binding CanManage}"
                                                Command="{Binding DataContext.DeleteGroupByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Name}" />
                                    </Grid>
                                </Expander.Header>

                                <Border Margin="0,10,0,0" Background="{DynamicResource SystemControlAcrylicElementBrush}" CornerRadius="8" Padding="10">
                                    <ListBox ItemsSource="{Binding Connections}"
                                             SelectedItem="{Binding DataContext.SelectedConnection, RelativeSource={RelativeSource AncestorType=Window}}"
                                             DoubleTapped="ConnectionsGrid_DoubleTapped">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Padding="10,8">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding Host}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Name}" Opacity="0.75" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Opacity="0.75" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SystemControlAcrylicElementBrush}" Padding="12" Margin="16" CornerRadius="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
                <TextBlock Text="{Binding ConfigFilePath}" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="打开配置" Command="{Binding OpenConfigCommand}" />
                <Button Grid.Column="2" Content="刷新" Command="{Binding ReloadConfigCommand}" />
            </Grid>
        </Border>
    </Grid>

</Window>
