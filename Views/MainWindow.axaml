<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteRDPTool.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1376" d:DesignHeight="768"
        x:Class="RemoteRDPTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Icon="/Assets/logo.ico"
        Title="RemoteRDPTool"
        Background="#F6F8FB"
        MinWidth="1180"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.navButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#DDDDDD" />
            <Setter Property="Padding" Value="8,14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="74" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.navButton:pointerover">
            <Setter Property="Background" Value="#5A5A5A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Button.navButton TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD" />
        </Style>
        <Style Selector="Button.navButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Button.searchAddMain">
            <Setter Property="Background" Value="#0B75D1" />
            <Setter Property="BorderBrush" Value="#0B75D1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="22,6" />
            <Setter Property="CornerRadius" Value="4,0,0,4" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style Selector="Button.searchAddDrop">
            <Setter Property="Background" Value="#0B75D1" />
            <Setter Property="BorderBrush" Value="#0B75D1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="0,4,4,0" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style Selector="TextBox.searchBox">
            <Setter Property="Background" Value="#29282D" />
            <Setter Property="BorderBrush" Value="#45444A" />
            <Setter Property="Foreground" Value="#E6ECF6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="Button.cardAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#44558F" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="Button.cardDelete">
            <Setter Property="Foreground" Value="#B75C52" />
        </Style>
        <Style Selector="Button.footerButton">
            <Setter Property="Background" Value="#29282D" />
            <Setter Property="BorderBrush" Value="#4A4950" />
            <Setter Property="Foreground" Value="#EAF0FC" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.groupContainer">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BoxShadow" Value="0 6 18 0 #26000000" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="false" />
        </Style>
        <Style Selector="Expander.groupExpander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Border.groupHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14,14,14,14" />
        </Style>
        <Style Selector="Button.groupHeaderAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#5A6A85" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinHeight" Value="24" />
        </Style>
        <Style Selector="Border.groupBody">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14,14,14,14" />
        </Style>
        <Style Selector="Border.connectionCard">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E2B93B" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BoxShadow" Value="0 4 10 0 #34000000" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>
        <Style Selector="TextBlock.detectingSpinner">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#4A78D0" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="RenderTransform">
                <RotateTransform Angle="0" />
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.9" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,40" ColumnDefinitions="104,*">
        <Border Background="#29282D" Grid.RowSpan="2">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="0,14,0,0" Spacing="10">
                    <Button Classes="navButton" Command="{Binding ShowConnectionsPageCommand}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="🖥" FontSize="30" HorizontalAlignment="Center" />
                            <TextBlock Text="Connection" FontSize="13" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!--<Button Classes="navButton">
                        <StackPanel Spacing="4">
                            <TextBlock Text="👥" HorizontalAlignment="Center" />
                            <TextBlock Text="Groups" FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>-->
                </StackPanel>
                <Button Grid.Row="2" Classes="navButton" Margin="8,0,8,12" Command="{Binding ShowSettingsPageCommand}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="⚙" FontSize="30" HorizontalAlignment="Center" />
                        <TextBlock Text="Settings" FontSize="16" HorizontalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <Border Background="#29282D" Padding="14,10" BorderBrush="#45444A" BorderThickness="0,0,0,1" IsVisible="{Binding IsConnectionPage}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="0">
                    <TextBox Classes="searchBox"
                             Watermark="Search Name/IP/Account/Share/Group"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Classes="searchAddMain"
                            Content="Add"
                            Command="{Binding AddConnectionCommand}" />
                    <Button Grid.Column="2" Classes="searchAddDrop" Content="▼">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Add Connection" Command="{Binding AddConnectionCommand}" />
                                <MenuItem Header="Add Group" Command="{Binding AddGroupCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          Margin="14,12,14,12"
                          IsVisible="{Binding IsConnectionPage}"
                          PointerPressed="ConnectionsArea_PointerPressed">
                <ItemsControl ItemsSource="{Binding GroupViews}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="groupContainer" Margin="0,0,0,12">
                                <Expander Classes="groupExpander" IsExpanded="{Binding IsExpanded}">
                                    <Expander.Header>
                                        <Border Classes="groupHeader" Padding="12,8">
                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#232A35" />
                                                <Button Grid.Column="1"
                                                        Classes="groupHeaderAction"
                                                        Content="Rename"
                                                        IsVisible="{Binding CanManage}"
                                                        Command="{Binding DataContext.RenameGroupByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Name}" />
                                                <Button Grid.Column="2"
                                                        Classes="groupHeaderAction"
                                                        Content="Delete"
                                                        IsVisible="{Binding CanManage}"
                                                        Command="{Binding DataContext.DeleteGroupByNameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Name}" />
                                            </Grid>
                                        </Border>
                                    </Expander.Header>
                                    <Border Classes="groupBody" Padding="12,12,12,2">
                                        <ListBox ItemsSource="{Binding Connections}"
                                                 SelectedItem="{Binding DataContext.SelectedConnection, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 DoubleTapped="ConnectionsGrid_DoubleTapped">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="3" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="connectionCard" Margin="0,0,12,10" Padding="14,10" HorizontalAlignment="Stretch" BorderBrush="{Binding PingBorderBrush}">
                                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#1B1F24" />
                                                                <TextBlock Grid.Column="1"
                                                                           Classes="detectingSpinner"
                                                                           Text="◔"
                                                                           IsVisible="{Binding IsChecking}" />
                                                                <Button Grid.Column="1"
                                                                        Classes="cardAction"
                                                                        Content="🔗"
                                                                        IsVisible="{Binding ShowQuickCheck}"
                                                                        Command="{Binding DataContext.CheckEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Entry}" />
                                                            </Grid>
                                                            <TextBlock Grid.Row="1" FontSize="12" Foreground="#2A2F36">
                                                                <Run Text="{Binding Host}" />
                                                                <Run Text=" - " />
                                                                <Run Text="{Binding Username}" />
                                                            </TextBlock>
                                                            <TextBlock Grid.Row="2" FontSize="12" Foreground="#5A6A85" Text="{Binding SharePathDisplay}" />
                                                            <Grid Grid.Row="3"
                                                                  ColumnDefinitions="Auto,*"
                                                                  ColumnSpacing="6"
                                                                  IsVisible="{Binding DataContext.ProcessWatchEnabled, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <TextBlock Text="进程" FontSize="12" Foreground="#5A6A85" />
                                                                <TextBlock Grid.Column="1" Text="{Binding ProcessStatus}" FontSize="12" Foreground="{Binding ProcessStatusBrush}" />
                                                            </Grid>
                                                            <Grid Grid.Row="4" ColumnDefinitions="*,1,*,1,*,1,*">
                                                                <Button Classes="cardAction"
                                                                        Content="🖥"
                                                                        ToolTip.Tip="远程连接"
                                                                        Command="{Binding DataContext.ConnectEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Entry}" />
                                                                <Border Grid.Column="1" Width="1" Background="#E1E6EE" Margin="6,0" />
                                                                <Button Grid.Column="2"
                                                                        Classes="cardAction"
                                                                        Content="📁"
                                                                        ToolTip.Tip="共享磁盘"
                                                                        Command="{Binding DataContext.OpenShareDiskEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Entry}" />
                                                                <Border Grid.Column="3" Width="1" Background="#E1E6EE" Margin="6,0" />
                                                                <Button Grid.Column="4"
                                                                        Classes="cardAction"
                                                                        Content="✏"
                                                                        ToolTip.Tip="编辑"
                                                                        Command="{Binding DataContext.EditEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Entry}" />
                                                                <Border Grid.Column="5" Width="1" Background="#E1E6EE" Margin="6,0" />
                                                                <Button Grid.Column="6"
                                                                        Classes="cardAction cardDelete"
                                                                        Content="🗑"
                                                                        ToolTip.Tip="删除"
                                                                        Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Entry}" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Margin="14,12,14,12"
                    Padding="16"
                    CornerRadius="12"
                    Background="#FFFFFF"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1"
                    IsVisible="{Binding IsSettingsPage}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Ping 设置" FontSize="16" FontWeight="SemiBold" Foreground="#1B1F24" />
                    <TextBlock Text="连续多次不通后自动降低检测频率" FontSize="13" Foreground="#5A6A85" />
                    <CheckBox Content="启用降频策略" IsChecked="{Binding AutoReducePingFrequency}" />
                    <Grid ColumnDefinitions="Auto,80,24,Auto,80" VerticalAlignment="Center">
                        <TextBlock Text="常规间隔(秒)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding PingIntervalSeconds}" HorizontalContentAlignment="Center" />
                        <TextBlock Grid.Column="2" Text=" " />
                        <TextBlock Grid.Column="3" Text="降频间隔(秒)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="4" Text="{Binding ReducedPingIntervalSeconds}" HorizontalContentAlignment="Center" />
                    </Grid>
                    <Separator Margin="0,6,0,4" />
                    <TextBlock Text="按键设置" FontSize="16" FontWeight="SemiBold" Foreground="#1B1F24" />
                    <TextBlock Text="点击输入框后按组合键，支持 Ctrl/Alt/Shift/Win + 按键" FontSize="13" Foreground="#5A6A85" />
                    <Grid ColumnDefinitions="Auto,220,*" VerticalAlignment="Center">
                        <TextBlock Text="唤出按键" VerticalAlignment="Center" />
                        <TextBox x:Name="SummonHotkeyInput"
                                 Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Watermark="Ctrl+R"
                                 IsReadOnly="True"
                                 Text="{Binding SummonHotkey}"
                                 GotFocus="SummonHotkeyInput_GotFocus"
                                 LostFocus="SummonHotkeyInput_LostFocus"
                                 KeyDown="SummonHotkeyInput_KeyDown" />
                    </Grid>
                    <Separator Margin="0,6,0,4" />
                    <TextBlock Text="进程检测设置" FontSize="16" FontWeight="SemiBold" Foreground="#1B1F24" />
                    <CheckBox Content="全局启用进程检测" IsChecked="{Binding ProcessWatchEnabled}" />
                    <Grid ColumnDefinitions="Auto,90,*" VerticalAlignment="Center">
                        <TextBlock Text="检测间隔(秒)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding ProcessWatchIntervalSeconds}" HorizontalContentAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,90,*" VerticalAlignment="Center">
                        <TextBlock Text="检测超时(秒)" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Margin="10,0,0,0" Text="{Binding ProcessWatchTimeoutSeconds}" HorizontalContentAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                        <TextBlock Text="进程名列表" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Watermark="例如：nginx.exe, java.exe"
                                 Text="{Binding ProcessWatchNamesText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="#29282D" BorderBrush="#45444A" BorderThickness="0,1,0,0" Padding="10,4">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                <TextBlock Text="{Binding ConfigFilePath}" Foreground="#8F9BB0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Classes="footerButton" Content="Open Config" Command="{Binding OpenConfigCommand}" />
                <Button Grid.Column="2" Classes="footerButton" Content="Refresh" Command="{Binding ReloadConfigCommand}" />
                <TextBlock Grid.Column="3"
                           Text="© 2026 zhongxiangying"
                           Foreground="#8F9BB0"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                ZIndex="999"
                Background="#700A111A"
                IsVisible="{Binding IsGlobalLoading}">
            <Border Width="320"
                    Padding="22,18"
                    CornerRadius="12"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1"
                    Background="#FFFFFF"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="10">
                    <TextBlock Classes="detectingSpinner"
                               HorizontalAlignment="Center"
                               FontSize="28"
                               Text="◔" />
                    <TextBlock Text="{Binding GlobalLoadingText}"
                               HorizontalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#1B1F24" />
                    <TextBlock Text="请稍候，超时会自动关闭，也可手动取消"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#5A6A85" />
                    <Button HorizontalAlignment="Center"
                            Width="96"
                            Height="34"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Background="#29282D"
                            BorderBrush="#4A4950"
                            Foreground="#EAF0FC"
                            CornerRadius="8"
                            Content="取消"
                            Command="{Binding CancelGlobalLoadingCommand}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
